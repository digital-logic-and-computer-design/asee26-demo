{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "type": "venus",
            "request": "launch",
            "name": "Launch with board view",
            "program": "${file}",
            "stopOnEntry": true,
            "stopAtBreakpoints": true,
            "openViews": [
                "Led and Key Board"
            ],
            "ledAndKey": {
                "hideBoard": false,
                "hideRGB": false,
                "hideUART": false,
                "baudRate": 57600,
                "clocksPerInst": 1,
                "clock": 6000000
            }
        }
    ]
}
